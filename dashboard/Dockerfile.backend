FROM python:3.11-slim

WORKDIR /app

# Install ZEUS dependencies
COPY requirements.txt /app/requirements.txt
COPY dashboard/backend/requirements.txt /app/dashboard_requirements.txt
RUN pip install --no-cache-dir -r requirements.txt -r dashboard_requirements.txt

# Copy full project
COPY . /app

EXPOSE 8081

CMD ["python", "-m", "uvicorn", "dashboard.backend.server:app", "--host", "0.0.0.0", "--port", "8081"]
