{
  "title": "Pantheon OS — Trading Overview",
  "uid": "pantheon-overview",
  "tags": ["pantheon", "trading"],
  "timezone": "Europe/Berlin",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [

    {
      "id": 1,
      "title": "Equity Curve",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 16, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT refreshed_at AS time, total_equity AS \"Equity (€)\", peak_equity AS \"Peak\" FROM portfolio_state WHERE refreshed_at > NOW() - INTERVAL '7 days' ORDER BY refreshed_at ASC",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "color": { "mode": "palette-classic" }
        }
      }
    },

    {
      "id": 2,
      "title": "Current Drawdown %",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT current_drawdown_pct * 100 AS value FROM portfolio_state ORDER BY refreshed_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 15,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 8 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "Total Equity",
      "type": "stat",
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT '€ ' || TO_CHAR(total_equity, 'FM999,999,990.00') AS value FROM portfolio_state ORDER BY refreshed_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "valueSize": 24 }
      }
    },

    {
      "id": 4,
      "title": "Win Rate by Signal Category",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 8, "w": 10, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT category, ROUND(win_rate * 100, 1) AS \"Win Rate %\", total_trades FROM get_win_rates_by_category() WHERE total_trades >= 5",
        "format": "table"
      }]
    },

    {
      "id": 5,
      "title": "Where Signals Die (Kill Stage Distribution)",
      "type": "piechart",
      "gridPos": { "x": 10, "y": 8, "w": 6, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT killed_at_stage AS \"Stage\", count AS \"Count\" FROM get_kill_stage_stats()",
        "format": "table"
      }]
    },

    {
      "id": 6,
      "title": "Agent Health",
      "type": "table",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT agent_name AS \"Agent\", status AS \"Status\", checked_at AS \"Last Check\" FROM get_agent_health_summary() ORDER BY agent_name",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [{
          "matcher": { "id": "byName", "options": "Status" },
          "properties": [{
            "id": "custom.displayMode",
            "value": "color-background"
          }, {
            "id": "mappings",
            "value": [
              { "type": "value", "options": { "healthy":  { "color": "green",  "index": 0 } } },
              { "type": "value", "options": { "degraded": { "color": "yellow", "index": 1 } } },
              { "type": "value", "options": { "failed":   { "color": "red",    "index": 2 } } }
            ]
          }]
        }]
      }
    },

    {
      "id": 7,
      "title": "Recent Trades",
      "type": "table",
      "gridPos": { "x": 0, "y": 16, "w": 16, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT recorded_at AS \"Time\", symbol AS \"Symbol\", side::TEXT AS \"Side\", ROUND(confidence::numeric, 2) AS \"Confidence\", ROUND(position_pct * 100, 2) AS \"Size %\", ROUND(pnl_pct * 100, 2) AS \"P&L %\", CASE WHEN hit IS NULL THEN 'OPEN' WHEN hit THEN 'WIN' ELSE 'LOSS' END AS \"Result\", category::TEXT AS \"Category\" FROM trades ORDER BY recorded_at DESC LIMIT 50",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [{
          "matcher": { "id": "byName", "options": "Result" },
          "properties": [{
            "id": "custom.displayMode", "value": "color-background"
          }, {
            "id": "mappings",
            "value": [
              { "type": "value", "options": { "WIN":  { "color": "green",  "index": 0 } } },
              { "type": "value", "options": { "LOSS": { "color": "red",    "index": 1 } } },
              { "type": "value", "options": { "OPEN": { "color": "blue",   "index": 2 } } }
            ]
          }]
        }]
      }
    },

    {
      "id": 8,
      "title": "Monthly Returns",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT month AS \"Month\", ROUND(win_rate * 100, 1) AS \"Win Rate %\", ROUND(avg_pnl_pct * 100, 2) AS \"Avg P&L %\" FROM get_monthly_returns() ORDER BY month ASC",
        "format": "table"
      }]
    },

    {
      "id": 9,
      "title": "Agent Seniority Levels",
      "type": "table",
      "gridPos": { "x": 0, "y": 24, "w": 14, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT agent_name AS \"Agent\", level::TEXT AS \"Level\", level_int AS \"Score\", live_trading_allowed AS \"Live OK\", evaluated_at AS \"Evaluated\" FROM agent_seniority ORDER BY level_int DESC, agent_name ASC",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Level" },
            "properties": [{
              "id": "custom.displayMode",
              "value": "color-background"
            }, {
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "Director":          { "color": "purple", "index": 0 } } },
                { "type": "value", "options": { "Managing Director": { "color": "blue",   "index": 1 } } },
                { "type": "value", "options": { "Principal":         { "color": "semi-dark-blue", "index": 2 } } },
                { "type": "value", "options": { "Senior":            { "color": "green",  "index": 3 } } }
              ]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Live OK" },
            "properties": [{
              "id": "custom.displayMode",
              "value": "color-background"
            }, {
              "id": "mappings",
              "value": [
                { "type": "value", "options": { "true":  { "color": "green", "index": 0 } } },
                { "type": "value", "options": { "false": { "color": "red",   "index": 1 } } }
              ]
            }]
          }
        ]
      }
    },

    {
      "id": 10,
      "title": "System Seniority",
      "type": "stat",
      "gridPos": { "x": 14, "y": 24, "w": 5, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT system_level AS value FROM system_seniority",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green",  "value": 1 },
              { "color": "blue",   "value": 2 },
              { "color": "purple", "value": 3 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "TRAINEE"   } } },
            { "type": "value", "options": { "1": { "text": "JUNIOR"    } } },
            { "type": "value", "options": { "2": { "text": "SENIOR"    } } },
            { "type": "value", "options": { "3": { "text": "PRINCIPAL" } } },
            { "type": "value", "options": { "4": { "text": "DIRECTOR"  } } }
          ]
        }
      }
    },

    {
      "id": 11,
      "title": "Live Trading Allowed",
      "type": "stat",
      "gridPos": { "x": 19, "y": 24, "w": 5, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT CASE WHEN live_trading_allowed THEN 'YES' ELSE 'NO' END AS value FROM system_seniority",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] },
          "mappings": [
            { "type": "value", "options": { "YES": { "color": "green", "text": "LIVE ENABLED"  } } },
            { "type": "value", "options": { "NO":  { "color": "red",   "text": "PAPER ONLY"    } } }
          ]
        }
      }
    },

    {
      "id": 12,
      "title": "Max Position Size",
      "type": "gauge",
      "gridPos": { "x": 14, "y": 28, "w": 10, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT max_position_pct * 100 AS value FROM system_seniority",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 5,
          "thresholds": {
            "steps": [
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 2 },
              { "color": "green",  "value": 3 }
            ]
          }
        }
      }
    },

    {
      "id": 13,
      "title": "Anthropic Budget Used",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 6 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT ROUND(SUM(cost_usd)::numeric, 4) AS value FROM llm_usage",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0, "max": 25,
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "yellow", "value": 15 },
              { "color": "red",    "value": 22 }
            ]
          },
          "displayName": "Spent of $25.00"
        }
      }
    },

    {
      "id": 14,
      "title": "Budget Remaining",
      "type": "stat",
      "gridPos": { "x": 6, "y": 32, "w": 6, "h": 6 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT ROUND((25.0 - COALESCE(SUM(cost_usd), 0))::numeric, 4) AS value FROM llm_usage",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "green",  "value": 10 }
            ]
          }
        }
      }
    },

    {
      "id": 15,
      "title": "Daily LLM Cost (USD)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 6 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT DATE_TRUNC('day', recorded_at) AS time, ROUND(SUM(cost_usd)::numeric, 4) AS \"Daily Cost ($)\" FROM llm_usage GROUP BY 1 ORDER BY 1 ASC",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20 }
        }
      }
    },

    {
      "id": 16,
      "title": "LLM Calls Today",
      "type": "stat",
      "gridPos": { "x": 0, "y": 38, "w": 6, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS value FROM llm_usage WHERE recorded_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }
        }
      }
    },

    {
      "id": 17,
      "title": "Cost per LLM Call (today avg)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 38, "w": 6, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT ROUND(AVG(cost_usd)::numeric, 5) AS value FROM llm_usage WHERE recorded_at > NOW() - INTERVAL '24 hours'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }
        }
      }
    },

    {
      "id": 18,
      "title": "Token Usage by Symbol (last 7d)",
      "type": "table",
      "gridPos": { "x": 12, "y": 38, "w": 12, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT symbol AS \"Symbol\", SUM(input_tokens) AS \"Input Tokens\", SUM(output_tokens) AS \"Output Tokens\", ROUND(SUM(cost_usd)::numeric, 4) AS \"Cost ($)\" FROM llm_usage WHERE recorded_at > NOW() - INTERVAL '7 days' GROUP BY symbol ORDER BY SUM(cost_usd) DESC LIMIT 20",
        "format": "table"
      }]
    }

  ]
}
