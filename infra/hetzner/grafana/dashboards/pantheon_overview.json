{
  "title": "Pantheon OS — Trading Overview",
  "uid": "pantheon-overview",
  "tags": ["pantheon", "trading"],
  "timezone": "Europe/Berlin",
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "panels": [

    {
      "id": 1,
      "title": "Portfolio Value",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT total_equity AS \"Portfolio Value\" FROM portfolio_state ORDER BY refreshed_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 95000 },
              { "color": "green",  "value": 100000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "background",
        "text": { "valueSize": 32 }
      }
    },

    {
      "id": 2,
      "title": "P&L vs Start",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT total_equity - 100000 AS \"P&L vs Start\" FROM portfolio_state ORDER BY refreshed_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "red",    "value": -5000 },
              { "color": "yellow", "value": 0 },
              { "color": "green",  "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "background",
        "text": { "valueSize": 28 }
      }
    },

    {
      "id": 3,
      "title": "Drawdown",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT ROUND((current_drawdown_pct * 100)::numeric, 2) AS \"Drawdown\" FROM portfolio_state ORDER BY refreshed_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "orange", "value": 5 },
              { "color": "red",    "value": 8 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "background",
        "text": { "valueSize": 28 }
      }
    },

    {
      "id": 4,
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "x": 11, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT open_positions AS \"Open Positions\" FROM portfolio_state ORDER BY refreshed_at DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue",   "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "background",
        "text": { "valueSize": 28 }
      }
    },

    {
      "id": 5,
      "title": "Win Rate",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT COALESCE(ROUND((AVG(CASE WHEN hit THEN 1.0 ELSE 0.0 END) * 100)::numeric, 1), 0) AS \"Win Rate\" FROM trades WHERE hit IS NOT NULL",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 45 },
              { "color": "green",  "value": 55 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "background",
        "text": { "valueSize": 28 }
      }
    },

    {
      "id": 6,
      "title": "Total Trades",
      "type": "stat",
      "gridPos": { "x": 17, "y": 0, "w": 3, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) AS \"Total Trades\" FROM trades",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "text" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "none",
        "text": { "valueSize": 28 }
      }
    },

    {
      "id": 7,
      "title": "Avg P&L / Trade",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT COALESCE(ROUND((AVG(pnl_pct) * 100)::numeric, 2), 0) AS \"Avg P&L\" FROM trades WHERE pnl_pct IS NOT NULL",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green",  "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "colorMode": "background",
        "text": { "valueSize": 28 }
      }
    },

    {
      "id": 10,
      "title": "Equity Curve",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT refreshed_at AS time, total_equity AS \"Equity\", peak_equity AS \"Peak\" FROM portfolio_state WHERE refreshed_at > NOW() - INTERVAL '30 days' ORDER BY refreshed_at ASC",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": true
          }
        },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Peak" },
          "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
            { "id": "custom.lineWidth", "value": 1 },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
            { "id": "custom.fillOpacity", "value": 0 }
          ]
        }]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 11,
      "title": "Drawdown %",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT refreshed_at AS time, current_drawdown_pct * 100 AS \"Drawdown %\" FROM portfolio_state WHERE refreshed_at > NOW() - INTERVAL '30 days' ORDER BY refreshed_at ASC",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "options": { "tooltip": { "mode": "single" } }
    },

    {
      "id": 20,
      "title": "P&L by Symbol",
      "type": "table",
      "gridPos": { "x": 0, "y": 12, "w": 14, "h": 10 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT symbol AS \"Symbol\", COUNT(*) AS \"Trades\", COUNT(*) FILTER (WHERE hit IS NOT NULL) AS \"Closed\", COUNT(*) FILTER (WHERE hit = TRUE) AS \"Wins\", COUNT(*) FILTER (WHERE hit = FALSE) AS \"Losses\", COALESCE(ROUND((AVG(CASE WHEN hit THEN 1.0 ELSE 0.0 END) FILTER (WHERE hit IS NOT NULL) * 100)::numeric, 1), 0) AS \"Win %\", COALESCE(ROUND((AVG(pnl_pct) FILTER (WHERE pnl_pct IS NOT NULL) * 100)::numeric, 2), 0) AS \"Avg P&L %\", COALESCE(ROUND((SUM(pnl_pct) FILTER (WHERE pnl_pct IS NOT NULL) * 100)::numeric, 2), 0) AS \"Total P&L %\", COALESCE(ROUND((MAX(pnl_pct) FILTER (WHERE pnl_pct IS NOT NULL) * 100)::numeric, 2), 0) AS \"Best %\", COALESCE(ROUND((MIN(pnl_pct) FILTER (WHERE pnl_pct IS NOT NULL) * 100)::numeric, 2), 0) AS \"Worst %\" FROM trades GROUP BY symbol ORDER BY \"Total P&L %\" DESC NULLS LAST",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Symbol" },
            "properties": [{ "id": "custom.align", "value": "left" }, { "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Avg P&L %" },
            "properties": [{ "id": "custom.displayMode", "value": "color-text" }, {
              "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 0.5 }] }
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Total P&L %" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 1 }] }
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Win %" },
            "properties": [{ "id": "custom.displayMode", "value": "color-text" }, {
              "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 45 }, { "color": "green", "value": 55 }] }
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Best %" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }, { "id": "custom.displayMode", "value": "color-text" }]
          },
          {
            "matcher": { "id": "byName", "options": "Worst %" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }, { "id": "custom.displayMode", "value": "color-text" }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Total P&L %", "desc": true }]
      }
    },

    {
      "id": 21,
      "title": "Open Positions",
      "type": "table",
      "gridPos": { "x": 14, "y": 12, "w": 10, "h": 10 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT symbol AS \"Symbol\", side::TEXT AS \"Side\", ROUND(qty::numeric, 4) AS \"Qty\", ROUND(avg_cost::numeric, 2) AS \"Entry\", ROUND(current_price::numeric, 2) AS \"Price\", ROUND(unrealized_pnl::numeric, 2) AS \"Unreal P&L\", ROUND((unrealized_pnl_pct * 100)::numeric, 2) AS \"Unreal %\", ROUND(stop_loss::numeric, 2) AS \"SL\", ROUND(take_profit::numeric, 2) AS \"TP\" FROM portfolio_positions WHERE closed_at IS NULL ORDER BY unrealized_pnl_pct DESC NULLS LAST",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Symbol" },
            "properties": [{ "id": "custom.align", "value": "left" }, { "id": "custom.width", "value": 75 }]
          },
          {
            "matcher": { "id": "byName", "options": "Side" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "LONG":  { "color": "green", "index": 0 } } },
                { "type": "value", "options": { "SHORT": { "color": "red",   "index": 1 } } }
              ]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Unreal %" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 1 }] }
            }]
          }
        ]
      }
    },

    {
      "id": 30,
      "title": "Where Signals Die",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 22, "w": 8, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT COALESCE(killed_at_stage, 'executed') AS \"Stage\", COUNT(*) AS \"Count\" FROM decision_traces GROUP BY killed_at_stage ORDER BY COUNT(*) DESC",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        }
      },
      "options": {
        "xField": "Stage",
        "orientation": "horizontal",
        "barWidth": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    },

    {
      "id": 31,
      "title": "Win Rate by Signal Category",
      "type": "barchart",
      "gridPos": { "x": 8, "y": 22, "w": 8, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT category::TEXT AS \"Category\", COUNT(*) AS \"Trades\", COALESCE(ROUND((AVG(CASE WHEN hit THEN 1.0 ELSE 0.0 END) FILTER (WHERE hit IS NOT NULL) * 100)::numeric, 1), 0) AS \"Win %\" FROM trades GROUP BY category ORDER BY \"Win %\" DESC",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 80 } }
      },
      "options": {
        "xField": "Category",
        "orientation": "horizontal",
        "barWidth": 0.7,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    },

    {
      "id": 32,
      "title": "P&L Distribution (closed trades)",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT bucket AS \"P&L Bucket\", COUNT(*) AS \"Count\" FROM ( SELECT CASE WHEN pnl_pct * 100 < -5  THEN '< -5%' WHEN pnl_pct * 100 < -3  THEN '-5 to -3%' WHEN pnl_pct * 100 < -1  THEN '-3 to -1%' WHEN pnl_pct * 100 < 0   THEN '-1 to 0%' WHEN pnl_pct * 100 < 1   THEN '0 to 1%' WHEN pnl_pct * 100 < 3   THEN '1 to 3%' WHEN pnl_pct * 100 < 5   THEN '3 to 5%' ELSE '> 5%' END AS bucket, CASE WHEN pnl_pct * 100 < -5  THEN 1 WHEN pnl_pct * 100 < -3  THEN 2 WHEN pnl_pct * 100 < -1  THEN 3 WHEN pnl_pct * 100 < 0   THEN 4 WHEN pnl_pct * 100 < 1   THEN 5 WHEN pnl_pct * 100 < 3   THEN 6 WHEN pnl_pct * 100 < 5   THEN 7 ELSE 8 END AS sort_order FROM trades WHERE pnl_pct IS NOT NULL ) t GROUP BY bucket, sort_order ORDER BY sort_order",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 } }
      },
      "options": {
        "xField": "P&L Bucket",
        "orientation": "vertical",
        "barWidth": 0.8,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "hidden" }
      }
    },

    {
      "id": 40,
      "title": "Recent Trades",
      "type": "table",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 9 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT recorded_at AS \"Time\", symbol AS \"Symbol\", side::TEXT AS \"Side\", category::TEXT AS \"Category\", ROUND((confidence * 100)::numeric, 1) AS \"Conf %\", ROUND((position_pct * 100)::numeric, 1) AS \"Size %\", ROUND(fill_price::numeric, 2) AS \"Fill\", ROUND(stop_loss::numeric, 2) AS \"SL\", ROUND(take_profit::numeric, 2) AS \"TP\", COALESCE(ROUND((pnl_pct * 100)::numeric, 2), NULL) AS \"P&L %\", CASE WHEN hit IS NULL THEN 'OPEN' WHEN hit THEN 'WIN' ELSE 'LOSS' END AS \"Result\", CASE WHEN paper_trading THEN 'PAPER' ELSE 'LIVE' END AS \"Mode\" FROM trades ORDER BY recorded_at DESC LIMIT 100",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Symbol" },
            "properties": [{ "id": "custom.align", "value": "left" }, { "id": "custom.width", "value": 80 }]
          },
          {
            "matcher": { "id": "byName", "options": "Category" },
            "properties": [{ "id": "custom.align", "value": "left" }, { "id": "custom.width", "value": 140 }]
          },
          {
            "matcher": { "id": "byName", "options": "Side" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "BUY":  { "color": "green", "index": 0 } } },
                { "type": "value", "options": { "SELL": { "color": "red",   "index": 1 } } }
              ]
            }, { "id": "custom.width", "value": 55 }]
          },
          {
            "matcher": { "id": "byName", "options": "Result" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "WIN":  { "color": "green", "index": 0 } } },
                { "type": "value", "options": { "LOSS": { "color": "red",   "index": 1 } } },
                { "type": "value", "options": { "OPEN": { "color": "blue",  "index": 2 } } }
              ]
            }, { "id": "custom.width", "value": 65 }]
          },
          {
            "matcher": { "id": "byName", "options": "P&L %" },
            "properties": [{ "id": "custom.displayMode", "value": "color-text" }, {
              "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 0.5 }] }
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Mode" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "PAPER": { "color": "blue",  "index": 0 } } },
                { "type": "value", "options": { "LIVE":  { "color": "green", "index": 1 } } }
              ]
            }, { "id": "custom.width", "value": 60 }]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Time", "desc": true }]
      }
    },

    {
      "id": 50,
      "title": "Agent Seniority",
      "type": "table",
      "gridPos": { "x": 0, "y": 39, "w": 14, "h": 8 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT s.agent_name AS \"Agent\", s.level::TEXT AS \"Level\", s.level_int AS \"Score\", s.max_position_pct * 100 AS \"Max Pos %\", s.live_trading_allowed AS \"Live OK\", s.cleared AS \"Cleared\", s.evaluated_at AS \"Evaluated\" FROM agent_seniority s ORDER BY s.level_int DESC, s.agent_name ASC",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "right" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Agent" },
            "properties": [{ "id": "custom.align", "value": "left" }, { "id": "custom.width", "value": 110 }]
          },
          {
            "matcher": { "id": "byName", "options": "Level" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "Director":          { "color": "purple",        "index": 0 } } },
                { "type": "value", "options": { "Managing Director": { "color": "blue",           "index": 1 } } },
                { "type": "value", "options": { "Principal":         { "color": "semi-dark-blue", "index": 2 } } },
                { "type": "value", "options": { "Senior":            { "color": "green",          "index": 3 } } }
              ]
            }, { "id": "custom.width", "value": 130 }]
          },
          {
            "matcher": { "id": "byName", "options": "Live OK" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "true":  { "color": "green", "text": "YES", "index": 0 } } },
                { "type": "value", "options": { "false": { "color": "red",   "text": "NO",  "index": 1 } } }
              ]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "Cleared" },
            "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "true":  { "color": "green", "text": "OK",   "index": 0 } } },
                { "type": "value", "options": { "false": { "color": "red",   "text": "FAIL", "index": 1 } } }
              ]
            }]
          }
        ]
      }
    },

    {
      "id": 51,
      "title": "System Level",
      "type": "stat",
      "gridPos": { "x": 14, "y": 39, "w": 5, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT system_level AS \"System Level\" FROM system_seniority",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "colorMode": "background",
        "justifyMode": "center",
        "text": { "valueSize": 20 }
      }
    },

    {
      "id": 52,
      "title": "Live Trading",
      "type": "stat",
      "gridPos": { "x": 19, "y": 39, "w": 5, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT CASE WHEN live_trading_allowed THEN 'ENABLED' ELSE 'PAPER ONLY' END AS \"Live Trading\" FROM system_seniority",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }] },
          "mappings": [
            { "type": "value", "options": { "ENABLED":    { "color": "green" } } },
            { "type": "value", "options": { "PAPER ONLY": { "color": "red"   } } }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value",
        "colorMode": "background",
        "justifyMode": "center",
        "text": { "valueSize": 18 }
      }
    },

    {
      "id": 53,
      "title": "Max Position Size",
      "type": "gauge",
      "gridPos": { "x": 14, "y": 43, "w": 5, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT max_position_pct * 100 AS \"Max Pos %\" FROM system_seniority",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 20,
          "thresholds": {
            "steps": [
              { "color": "blue",   "value": 0 },
              { "color": "green",  "value": 5 },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 15 }
            ]
          }
        }
      }
    },

    {
      "id": 54,
      "title": "Promotion History",
      "type": "table",
      "gridPos": { "x": 19, "y": 43, "w": 5, "h": 4 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT agent_name AS \"Agent\", from_level::TEXT AS \"From\", to_level::TEXT AS \"To\", promoted_at AS \"When\" FROM agent_seniority_history ORDER BY promoted_at DESC LIMIT 20",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } }
      }
    },

    {
      "id": 60,
      "title": "Agent Health",
      "type": "table",
      "gridPos": { "x": 0, "y": 47, "w": 10, "h": 7 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT DISTINCT ON (agent_name) agent_name AS \"Agent\", status::TEXT AS \"Status\", COALESCE(message, '') AS \"Message\", checked_at AS \"Last Check\" FROM agent_health ORDER BY agent_name, checked_at DESC",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Status" },
          "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
            "id": "mappings", "value": [
              { "type": "value", "options": { "healthy":  { "color": "green",  "index": 0 } } },
              { "type": "value", "options": { "degraded": { "color": "yellow", "index": 1 } } },
              { "type": "value", "options": { "failed":   { "color": "red",    "index": 2 } } }
            ]
          }, { "id": "custom.width", "value": 85 }]
        }]
      }
    },

    {
      "id": 61,
      "title": "Monthly Returns",
      "type": "barchart",
      "gridPos": { "x": 10, "y": 47, "w": 8, "h": 7 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT TO_CHAR(DATE_TRUNC('month', recorded_at), 'Mon YY') AS \"Month\", COALESCE(ROUND((SUM(pnl_pct) FILTER (WHERE pnl_pct IS NOT NULL) * 100)::numeric, 2), 0) AS \"Total P&L %\", COUNT(*) AS \"Trades\" FROM trades GROUP BY DATE_TRUNC('month', recorded_at) ORDER BY DATE_TRUNC('month', recorded_at) ASC",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 80 } },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Total P&L %" },
          "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
            "id": "thresholds", "value": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0 }] }
          }]
        }]
      },
      "options": {
        "xField": "Month",
        "barWidth": 0.7,
        "tooltip": { "mode": "multi" }
      }
    },

    {
      "id": 62,
      "title": "Pipeline Activity (24h)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 47, "w": 6, "h": 7 },
      "datasource": { "uid": "supabase-postgres" },
      "targets": [{
        "rawSql": "SELECT DATE_TRUNC('hour', timestamp) AS time, COUNT(*) FILTER (WHERE zeus_approved = TRUE) AS \"Approved\", COUNT(*) FILTER (WHERE zeus_approved = FALSE) AS \"Rejected\" FROM decision_traces WHERE timestamp > NOW() - INTERVAL '24 hours' GROUP BY DATE_TRUNC('hour', timestamp) ORDER BY time ASC",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Approved" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Rejected" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }

  ]
}
