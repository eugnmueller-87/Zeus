# ============================================================
# Pantheon OS — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── Anthropic (ZEUS LLM reasoning) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (Postgres + pgvector + Realtime) ─────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # Backend only — full DB access
SUPABASE_ANON_KEY=eyJ...                  # Frontend (read-only via RLS)

# Supabase direct Postgres connection (for Grafana datasource)
# Get from: Supabase Dashboard → Settings → Database → Connection string
SUPABASE_DB_HOST=db.YOUR_PROJECT_ID.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD     # same as Supabase project password

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=choose_a_strong_password

# ── Upstash Redis (SpendLens bridge — zeus:* keys) ────────────
# Get from: Upstash Console → Redis → REST API
UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ── Hermes API (live market signals) ──────────────────────────
HERMES_API_KEY=
HERMES_BASE_URL=https://hermes-agent-production-114e.up.railway.app

# ── Interactive Brokers ───────────────────────────────────────
IB_USERNAME=your_ib_username
IB_PASSWORD=your_ib_password
IB_HOST=ibgateway                         # Docker service name in prod; 127.0.0.1 for local
IB_PORT=4002                              # 4002=paper (IB Gateway), 4001=live
IB_CLIENT_ID=1

# ── Telegram Alerts ───────────────────────────────────────────
# Get from: @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── FRED API (macro data — free) ──────────────────────────────
# Get from: fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── SEC EDGAR (historical ingestion) ──────────────────────────
# EDGAR requires a User-Agent with contact info (their terms of use)
# Use your email or a project contact address
EDGAR_USER_AGENT=your-email@example.com

# ── Hades compliance blocklist extensions (optional, comma-separated) ─
# HADES_OFAC_BLOCKLIST=GAZPROM,VTB                  # appended to built-in list
# HADES_ESG_BLOCKLIST=gambling,fur                  # appended to built-in list
# HADES_BLOCKED_TICKERS=RBLX,GME                   # hard-blocked tickers

# ── Tuning knobs (optional — defaults shown) ──────────────────
PYTHIA_MIN_SAMPLES=10           # minimum trades before using observed hit rate
PYTHIA_DEFAULT_SIZE_PCT=0.02    # fallback position size when no history
PYTHIA_MIN_CONFIDENCE=0.45      # minimum pattern confidence to pass sizing
APOLLO_ARXIV_MAX_PAPERS=5       # papers fetched per arXiv category per cycle
APOLLO_SELF_IMPROVE_N=50        # decision traces analysed per self-improvement run

# ── API Security ──────────────────────────────────────────────
# Shared secret for POST /run /halt /resume. Unset = auth disabled (local dev).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ZEUS_API_KEY=

# ── Hetzner server (for deploy scripts) ───────────────────────
HETZNER_SERVER_IP=YOUR_SERVER_IP
HETZNER_SSH_KEY=~/.ssh/id_rsa

# ── GitHub Container Registry (for CI/CD image push) ──────────
GHCR_TOKEN=ghp_...                        # GitHub PAT with write:packages scope

# ── Production domain ─────────────────────────────────────────
PRODUCTION_DOMAIN=pantheon.yourdomain.com

# ── Dashboard (Cloudflare Pages env vars — prefix VITE_) ──────
# Set these in Cloudflare Pages dashboard, NOT in this file
# VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_WS_URL=wss://pantheon.yourdomain.com/ws
# VITE_API_URL=https://pantheon.yourdomain.com/api
