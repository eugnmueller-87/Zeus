# ============================================================
# Pantheon OS — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ── Anthropic (ZEUS LLM reasoning) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (Postgres + pgvector + Realtime) ─────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # Backend only — full DB access
SUPABASE_ANON_KEY=eyJ...                  # Frontend (read-only via RLS)

# ── Upstash Redis (SpendLens bridge — zeus:* keys) ────────────
# Get from: Upstash Console → Redis → REST API
UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# ── Hermes API (live market signals — Railway) ────────────────
HERMES_API_KEY=
HERMES_BASE_URL=https://hermes-agent-production-114e.up.railway.app

# ── Interactive Brokers ───────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497                              # 7497=paper, 7496=live
IB_CLIENT_ID=1

# ── Telegram Alerts ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Hetzner server (for deploy scripts) ───────────────────────
HETZNER_SERVER_IP=YOUR_SERVER_IP
HETZNER_SSH_KEY=~/.ssh/id_rsa

# ── GitHub Container Registry (for CI/CD image push) ──────────
GHCR_TOKEN=ghp_...                        # GitHub PAT with write:packages scope

# ── Production domain ─────────────────────────────────────────
PRODUCTION_DOMAIN=pantheon.yourdomain.com

# ── Dashboard (Cloudflare Pages env vars — prefix VITE_) ──────
# Set these in Cloudflare Pages dashboard, NOT in this file
# VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_WS_URL=wss://pantheon.yourdomain.com/ws
# VITE_API_URL=https://pantheon.yourdomain.com/api
